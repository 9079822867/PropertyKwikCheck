{
  "info": {
    "name": "PropertyKwikCheck API",
    "_postman_id": "a1b2c3d4-0000-4a5b-9c1d-propertykwik01",
    "description": "Valuation workflow API. Set the `baseUrl` variable, run **Auth > Login** first (it auto-saves `token` & `refreshToken`), then every other request inherits Bearer auth.\n\nBase URL prod: https://property.kwikcheck.in/api  |  local: http://localhost:5107/api\n\nError envelope: { error, code, details } with codes VALIDATION/UNAUTHORIZED/FORBIDDEN/NOT_FOUND/INTERNAL.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5107/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "email", "value": "superadmin@kwikcheck.in", "type": "string" },
    { "key": "password", "value": "Password@123", "type": "string" },
    { "key": "leadId", "value": "4812", "type": "string" },
    { "key": "userId", "value": "21", "type": "string" },
    { "key": "companyId", "value": "11", "type": "string" },
    { "key": "docId", "value": "88", "type": "string" },
    { "key": "photoId", "value": "301", "type": "string" },
    { "key": "masterId", "value": "3", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "if (b.token) { pm.collectionVariables.set('token', b.token); }",
                  "if (b.refreshToken) { pm.collectionVariables.set('refreshToken', b.refreshToken); }",
                  "console.log('Saved token for', b.user && b.user.email);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const b = pm.response.json();",
                  "if (b.token) { pm.collectionVariables.set('token', b.token); }",
                  "if (b.refreshToken) { pm.collectionVariables.set('refreshToken', b.refreshToken); }"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
