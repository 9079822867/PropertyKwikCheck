{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PropertyDb": "REPLACE_IN_appsettings.Development.json_OR_USER_SECRETS"
  },
  "Jwt": {
    "Issuer": "PropertyKwikCheck",
    "Audience": "PropertyKwikCheck",
    "SigningKey": "REPLACE_WITH_A_32+_CHAR_SECRET_IN_DEV_SETTINGS_OR_SECRETS",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14
  },
  "Cors": {
    "Origins": [ "http://localhost:3000", "http://localhost:5173" ]
  },
  "Storage": {
    "Root": "storage"
  }
}
