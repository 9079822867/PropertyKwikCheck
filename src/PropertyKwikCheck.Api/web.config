<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS hosting config (no secrets — safe to commit). `dotnet publish` transforms this,
  updating the <aspNetCore> element, and preserves the WebDAV removal below.

  Why the WebDAV removal: IIS's WebDAVModule claims DELETE/PUT verbs and answers them
  with 405 Method Not Allowed BEFORE the request reaches ASP.NET Core. Removing it lets
  DELETE /api/photos/{id}, PATCH, etc. reach the app.

  Secrets (ConnectionStrings__PropertyDb, Jwt__SigningKey) are NOT here — supply them via
  appsettings.Production.json or IIS app-pool environment variables (see DEPLOY.md).
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <modules runAllManagedModulesForAllRequests="false">
        <remove name="WebDAVModule" />
      </modules>
      <handlers>
        <remove name="WebDAV" />
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\PropertyKwikCheck.Api.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
    </system.webServer>
  </location>
</configuration>
