# --- Dev (npm run dev) ---
# The Axios client calls same-origin "/api"; Vite proxies it to the backend below.
VITE_API_TARGET=http://localhost:5107

# --- Production (npm run build) ---
# Absolute base URL of the live API. Leave unset to use same-origin "/api"
# (only correct if the SPA is hosted on the same domain as the API).
# VITE_API_BASE_URL=https://property.kwikcheck.in/api
